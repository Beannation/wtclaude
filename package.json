{
  "name": "wtclaude",
  "version": "0.1.7",
  "description": "Billing-grade cost tracking for Claude Code — reads the statusline (the source behind your bill), not the session logs. Free and open source.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "wtclaude": "bin/wtclaude.js",
    "wtclaude-collector": "src/collector/index.js"
  },
  "files": [
    "bin/",
    "src/",
    "!**/*.test.js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "token-tracker",
    "usage",
    "anthropic"
  ],
  "scripts": {
    "test": "node --test src/**/*.test.js bin/*.test.js"
  },
  "dependencies": {
    "commander": "^13.0.0"
  }
}
