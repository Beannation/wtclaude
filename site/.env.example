# Umami analytics (self-hosted). Copy this file to `.env` and fill in both values.
# Both are PUBLIC_ (exposed to the browser) and baked in at build time.

# The full tracker script URL from your Umami instance.
#   Umami v2 default:  https://your-umami-host.com/script.js
#   Umami v1 default:  https://your-umami-host.com/umami.js
#   (If you use a Cloud/Vercel deploy of Umami, copy the src from the tracking-code snippet.)
PUBLIC_UMAMI_SRC=

# The Website ID (UUID) from Umami → Settings → Websites → your site → "Website ID".
PUBLIC_UMAMI_WEBSITE_ID=
