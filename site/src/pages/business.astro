---
import BaseLayout from '../layouts/BaseLayout.astro';
import Mark from '../components/Mark.astro';
import CaptureForm from '../components/CaptureForm.astro';
import HookBand from '../components/HookBand.astro';

// SMB copy — Messaging v1.12 ("the bundle") §1, applied VERBATIM. NO pricing — waitlist CTA.
const title =
  "WTClaude for Business — the independent, all-in-one way to run your team's Claude spend (coming soon)";
const description =
  "One independent, billing-grade place to run Claude for your team: see under the cap in real time, never pay for a seat nobody's using, and give every team lead their own view. Coming soon.";
---

<BaseLayout title={title} description={description} noNavPad heroDark>
  <!-- HERO (lead message — SMB copy v1.12 §1, verbatim) -->
  <section class="relative overflow-hidden bg-ink text-surface">
    <div
      class="pointer-events-none absolute inset-0 opacity-70"
      style="background: radial-gradient(60% 50% at 50% 0%, rgba(232,148,58,0.18) 0%, rgba(26,25,21,0) 70%);"
    >
    </div>
    <div class="relative mx-auto max-w-3xl px-5 pb-16 pt-32 text-center sm:pt-36">
      <Mark class="mx-auto mb-7 h-14 w-14 text-surface" />
      <span class="inline-block rounded-full bg-surface/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-surface/70">Coming soon · for teams</span>
      <h1 class="mt-5 font-head text-4xl leading-tight sm:text-5xl">
        Run your team's Claude spend — in one independent place.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-surface/80">
        Anthropic sells you the seats. WTClaude is the independent, billing-grade layer that helps
        you spend the right amount on them: real-time alerts under the cap, seats right-sized so you
        never pay for idle ones, and a view for every team lead. Coming soon.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-5 py-16">
    <!-- The three hero cards (v1.12 §1): see-under-the-cap · never-pay-for-an-unused-seat · delegated team-lead views -->
    <div class="grid gap-6 md:grid-cols-3">
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h2 class="font-head text-lg">See under the cap — in real time</h2>
        <p class="mt-2 text-sm leading-relaxed text-ink/70">
          Anthropic lets you set a ceiling but shows nothing happening underneath it until the bill.
          WTClaude shows live per-person spend under the cap and alerts you to a runaway in minutes,
          not at invoice time.
        </p>
        <p class="mt-3 text-xs leading-relaxed text-ink/55">
          Real-time runs on our lightweight collector or your admin's OTel export — not Anthropic's
          once-a-day data. A quick setup step we're upfront about.
        </p>
      </article>
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h2 class="font-head text-lg">Never pay for a seat nobody's using</h2>
        <p class="mt-2 text-sm leading-relaxed text-ink/70">
          Premium is 5× the price of Standard — for capacity, not features. WTClaude watches every
          seat and tells you which Premium seats fit Standard and which sit idle, and pushes you the
          heads-up — so reclaiming the waste isn't a manual chore you forget. You confirm the change;
          we never touch your account.
        </p>
      </article>
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h2 class="font-head text-lg">Give every team lead their own view</h2>
        <p class="mt-2 text-sm leading-relaxed text-ink/70">
          On a Team plan, only the owner can see analytics. WTClaude gives each team lead a view
          scoped to their own team, rolling up to leadership automatically — enterprise-grade
          management without the enterprise plan. It's cost-management, never surveillance.
        </p>
      </article>
    </div>

    <!-- The package line (centered) -->
    <p class="mx-auto mt-12 max-w-3xl text-center text-sm leading-relaxed text-ink/70">
      No single tool does all of this for a team your size — that's the point. WTClaude for Business
      is the one independent, billing-grade, one-pane package for the person who owns Claude spend:
      the real-time watchdog, the seat optimizer, delegated team-lead views, and the finance tools —
      assembled, not bolted together from five vendors.
    </p>

    <!-- How it connects to your team's Claude (the 3 paths, low-friction in) -->
    <p class="mx-auto mt-8 max-w-3xl text-center text-sm leading-relaxed text-ink/70">
      Connect your way: a 30-second Claude Code plugin to start (and when you pair it with Claude's
      own cost field, your numbers are billing-grade, with the git context other plugins miss); our
      desktop collector for billing-grade terminal Code + Cowork; or one admin OTel setting for the
      whole org at once. Start light, upgrade to the best data when you're ready — every number is
      labeled for exactly how it was measured.
    </p>

    <!-- Positioning / honesty line (centered) -->
    <p class="mx-auto mt-6 max-w-3xl text-center text-sm leading-relaxed text-ink/65">
      We're the insight + recommendation layer — hard caps are Anthropic's admin tier; we make your
      guardrails smart, we don't impose them. Independent: Anthropic sells the seats, so our advice
      on how many you need is unconflicted. Built on top of Anthropic's own team spend data — we
      enrich it, we don't re-run it.
    </p>

    <!-- The free hook (v1.12 §1) — LIVE: links to the client-side spend audit (SMB-V2). -->
    <div class="mx-auto mt-12 max-w-2xl rounded-2xl border border-amber/40 bg-amber-light/50 p-7 text-center shadow-sm">
      <span class="inline-block rounded-full border border-amber/40 bg-card px-3 py-1 text-xs font-semibold uppercase tracking-wide text-amber-deep">Free · live now</span>
      <p class="mt-4 font-head text-lg">Start free: the 30-second spend audit</p>
      <p class="mx-auto mt-2 max-w-xl text-sm leading-relaxed text-ink/70">
        Drop your Anthropic Spend Report CSV and see what you're overpaying on idle seats, spend
        concentration, model mix and $/request outliers — right in your browser, your data never
        leaves it. No signup for the headline number.
      </p>
      <a
        href="/business/audit"
        class="mt-5 inline-flex rounded-lg bg-amber px-5 py-2.5 text-sm font-semibold text-ink transition hover:bg-amber-deep hover:text-white"
        data-track="cta_spend_audit"
      >Run the free spend audit →</a>
    </div>

    <!-- CTA: email-signup capture (no pricing — embargo) -->
    <div class="mx-auto mt-10 max-w-md rounded-2xl border border-ink/10 bg-card p-7 text-center shadow-sm">
      <p class="font-head text-lg">Get notified when the full product ships</p>
      <div class="mt-4">
        <CaptureForm tag="smb" event="guardian_waitlist" cta="Notify me" />
      </div>
    </div>

    <p class="mt-8 text-center text-sm">
      <a href="/business/finance" class="font-semibold text-amber-deep hover:text-amber">For finance teams →</a>
    </p>
  </section>

  <HookBand />

  <script>
    function initBusinessPage() {
      try {
        (window as any).umami?.track('lp_view_smb_tease');
      } catch {
        /* no-op */
      }
    }
    initBusinessPage();
    document.addEventListener('astro:page-load', initBusinessPage);
  </script>
</BaseLayout>
