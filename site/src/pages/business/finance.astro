---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Mark from '../../components/Mark.astro';
import HonestyBadge from '../../components/HonestyBadge.astro';
import CaptureForm from '../../components/CaptureForm.astro';
import HookBand from '../../components/HookBand.astro';

const title = 'WTClaude for Finance — close the month on Claude, to the dollar (coming soon)';
const description =
  "Close the month on Claude to the dollar: allocation and chargeback on top of Anthropic's team spend data, a pre-invoice accrual, and the 150-seat cliff — the finance view for whoever has to explain the Claude line item. Coming soon.";
---

<BaseLayout title={title} description={description} noNavPad heroDark>
  <!-- HERO (lead message — SMB copy v1.11 §2, verbatim) -->
  <section class="relative overflow-hidden bg-ink text-surface">
    <div
      class="pointer-events-none absolute inset-0 opacity-70"
      style="background: radial-gradient(60% 50% at 50% 0%, rgba(232,148,58,0.18) 0%, rgba(26,25,21,0) 70%);"
    >
    </div>
    <div class="relative mx-auto max-w-3xl px-5 pb-16 pt-32 text-center sm:pt-36">
      <Mark class="mx-auto mb-7 h-14 w-14 text-surface" />
      <span class="inline-block rounded-full bg-surface/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-surface/70">Coming soon · for finance teams</span>
      <h1 class="mt-5 font-head text-4xl leading-tight sm:text-5xl">
        Close the month on Claude, to the dollar — and right-size the cap.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-surface/80">
        Allocation and chargeback, a pre-invoice accrual, and the 150-seat cliff — built for whoever
        has to explain (and forecast) the Claude line item.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-5 py-16">
    <!-- Co-heroes: allocation & chargeback + pre-invoice accrual -->
    <div class="grid gap-6 md:grid-cols-2">
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h2 class="font-head text-xl">Allocation &amp; chargeback</h2>
        <p class="mt-3 text-sm leading-relaxed text-ink/70">
          Anthropic's Team plan now gives you a per-user/per-model spend CSV. We turn it into
          allocation and chargeback by team, project, or cost center — so you can close your books,
          not just read a list.
        </p>
      </article>
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <div class="flex flex-wrap items-center gap-1.5">
          <h2 class="font-head text-xl">Pre-invoice accrual</h2>
          <HonestyBadge kind="estimate" />
        </div>
        <p class="mt-3 text-sm leading-relaxed text-ink/70">
          Know roughly what the bill will be before the invoice lands — a clearly-labeled accrual to
          book against, not a month-end surprise.
        </p>
      </article>
    </div>

    <!-- Support cards: budget vs. actual + cliff-management -->
    <div class="mt-6 grid gap-6 md:grid-cols-2">
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h3 class="font-head text-lg">Budget vs. actual, and right-sizing the cap</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink/70">
          Watch spend against budget as the month runs, so you can set the right caps — ones that
          protect the budget without throttling your best engineers, informed by who actually needs
          the headroom. We recommend and alert; you set the cap, and we don't enforce it.
        </p>
      </article>
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h3 class="font-head text-lg">Cliff-management</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink/70">
          See the 150-seat Team→Enterprise cliff coming and right-size seats and models to delay or
          survive it. (One operator reported jumping from roughly $400K to $1.4M crossing it — his
          figure, not Anthropic's; the mechanic is real: Enterprise seats are access-only, every Code
          token at API rates on top.)
        </p>
      </article>
    </div>

    <!-- Honesty guardrails (centered) -->
    <p class="mx-auto mt-12 max-w-3xl text-center text-sm leading-relaxed text-ink/65">
      The accrual is a clearly-labeled estimate of the bill — not the guaranteed invoice. This is
      cost allocation, not employee monitoring. We build on top of Anthropic's own team spend data;
      we measure and recommend — we never cap or cut off your team. Allocation and accrual are
      billing-grade on Code where your admin enables OTel (team-level Code cost rides Anthropic's
      OTel export), otherwise a clearly-labeled estimate; on Cowork the same OTel caveat applies.
    </p>

    <!-- CTA: email-signup capture (no pricing — embargo) -->
    <div class="mx-auto mt-12 max-w-md rounded-2xl border border-ink/10 bg-card p-7 text-center shadow-sm">
      <p class="font-head text-lg">Get notified at launch</p>
      <div class="mt-4">
        <CaptureForm tag="smb_finance" event="guardian_waitlist" cta="Notify me" />
      </div>
    </div>

    <p class="mt-8 text-center text-sm">
      <a href="/business" class="font-semibold text-amber-deep hover:text-amber">← Back to WTClaude for Business</a>
    </p>
  </section>

  <HookBand />

  <script>
    function initFinancePage() {
      try {
        (window as any).umami?.track('lp_view_smb_tease', { page: 'finance' });
      } catch {
        /* no-op */
      }
    }
    initFinancePage();
    document.addEventListener('astro:page-load', initFinancePage);
  </script>
</BaseLayout>
