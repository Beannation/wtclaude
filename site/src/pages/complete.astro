---
import BaseLayout from '../layouts/BaseLayout.astro';
import Mark from '../components/Mark.astro';
import HonestyBadge from '../components/HonestyBadge.astro';
import CaptureForm from '../components/CaptureForm.astro';
import DraftNote from '../components/DraftNote.astro';
import HookBand from '../components/HookBand.astro';

const title = 'WTClaude for the Complete Claude User — all your Claude in one view';
const description =
  'See your whole Claude life in one place — Chat, Cowork, and Code — with a warning before you hit a limit. Billing-grade for Code in your terminal; an honest estimate for Code in the desktop app, and clearly-labeled estimates for the rest.';
---

<BaseLayout title={title} description={description} noNavPad heroDark>
  <!-- HERO (lead message + bridge — Strategy brief A2, verbatim) -->
  <section class="relative overflow-hidden bg-ink text-surface">
    <div
      class="pointer-events-none absolute inset-0 opacity-70"
      style="background: radial-gradient(60% 50% at 50% 0%, rgba(232,148,58,0.18) 0%, rgba(26,25,21,0) 70%);"
    >
    </div>
    <div class="relative mx-auto max-w-3xl px-5 pb-16 pt-32 text-center sm:pt-36">
      <Mark class="mx-auto mb-7 h-14 w-14 text-surface" />
      <span class="inline-block rounded-full bg-surface/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-surface/70">Coming soon · Wave 2</span>
      <h1 class="mt-5 font-head text-4xl leading-tight sm:text-5xl">
        See your whole Claude life in one place — and never get stuck waiting again.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-surface/80">
        The accurate tracker devs trust — now built for everyone.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-5 py-16">
    <DraftNote brief="Strategy brief A2 (Complete Claude User)" class="mb-12" />

    <!-- Co-heroes: attributed limit view + learning layer -->
    <div class="grid gap-6 md:grid-cols-2">
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h2 class="font-head text-xl">The attributed limit view</h2>
        <p class="mt-3 text-sm leading-relaxed text-ink/70">
          Where your limit actually went — across Chat, Cowork, and Code.
        </p>
      </article>
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h2 class="font-head text-xl">The learning layer</h2>
        <p class="mt-3 text-sm leading-relaxed text-ink/70">
          Teaches you your own patterns — a daily learning debrief in plain language.
        </p>
      </article>
    </div>

    <!-- Support points (Strategy brief A2) -->
    <div class="mt-6 grid gap-6 md:grid-cols-3">
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h3 class="font-head text-lg">Free</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink/70">The unified view is free in Phase 0.</p>
      </article>
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <div class="flex flex-wrap items-center gap-1.5">
          <h3 class="font-head text-lg">Honest by surface</h3>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-ink/70">
          Billing-grade for Code in your terminal <HonestyBadge kind="billing-grade" />; an honest
          estimate for Code in the desktop app <HonestyBadge kind="estimate" />; a clearly-labeled
          estimate for Cowork <HonestyBadge kind="estimate" />, and Chat reflected in the shared
          limit total.
        </p>
      </article>
      <article class="rounded-2xl border border-ink/10 bg-card p-7 shadow-sm">
        <h3 class="font-head text-lg">Daily learning debrief</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink/70">Plain-language answers, including the evidence-based “is Max worth it?”</p>
      </article>
    </div>

    <!-- Honesty framing (do-NOT-claim guardrails, brief A2 + labeling spec) -->
    <p class="mx-auto mt-10 max-w-3xl text-center text-sm leading-relaxed text-ink/65">
      Code cost is billing-grade in your terminal; an honest estimate in the desktop app. Cowork is
      a clearly-labeled estimate. Chat has no local data, so it’s reflected only inside your shared
      limit total — never shown as a Chat dollar figure. The limit view reflects Anthropic’s shared
      rate-limit data, read as accurately as we can.
    </p>

    <!-- CTA: "download the companion" → notify-me (companion not shipped yet) -->
    <div class="mx-auto mt-12 max-w-md rounded-2xl border border-ink/10 bg-card p-7 text-center shadow-sm">
      <p class="font-head text-lg">Download the companion</p>
      <p class="mt-1 text-sm text-ink/60">Coming soon — get notified when it’s ready.</p>
      <div class="mt-4">
        <CaptureForm tag="complete" event="guardian_waitlist" cta="Notify me" />
      </div>
    </div>
  </section>

  <HookBand />

  <script>
    function initCompletePage() {
      try {
        (window as any).umami?.track('lp_view_complete');
      } catch {
        /* no-op */
      }
    }
    initCompletePage();
    document.addEventListener('astro:page-load', initCompletePage);
  </script>
</BaseLayout>
