---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<BaseLayout title="Blog — WTClaude" description="Notes on Claude usage, billing, and tracking honestly.">
  <section class="mx-auto max-w-[720px] px-5 py-16">
    <h1 class="font-head text-4xl">Blog</h1>
    <ul class="mt-10 space-y-8">
      {
        posts.map((post) => (
          <li class="border-b border-ink/10 pb-8">
            <a href={`/blog/${post.id}`} class="group block">
              <h2 class="font-head text-xl text-ink group-hover:text-amber-deep">{post.data.title}</h2>
              <p class="mt-2 text-sm text-warm">
                {fmt(post.data.pubDate)}
                {post.data.readingTime ? ` · ${post.data.readingTime}` : ''}
              </p>
              <p class="mt-3 text-sm leading-relaxed text-ink/70">{post.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
