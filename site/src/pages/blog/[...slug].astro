---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { blogPosting, faqPage, breadcrumbs } from '../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/assets/og-default.png', Astro.site).href;

// BlogPosting + (optional) FAQPage + BreadcrumbList for the post (§4A).
const jsonLd: object[] = [
  blogPosting({
    url: canonical,
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    author: post.data.author,
    image: ogImage,
  }),
  breadcrumbs([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
    { name: post.data.title, path: `/blog/${post.id}` },
  ]),
];
if (post.data.faq?.length) jsonLd.push(faqPage(post.data.faq));
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  author={post.data.author}
  readingTime={post.data.readingTime}
  draftProse={post.data.draftProse}
  jsonLd={jsonLd}
>
  <Content />
</BlogLayout>
