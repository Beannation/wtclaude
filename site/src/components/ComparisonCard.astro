---
import HonestyBadge from './HonestyBadge.astro';

/**
 * THE centerpiece — "see your own gap" (PM-PUB-004 · GTM canonical surface F).
 * The hardcoded $3.42 → $18.70 "Reality" counter is GONE: we show the method
 * (session logs vs statusline) and invite you to run `wtclaude compare` to see
 * YOUR own number. No fabricated figures are shown (no live values here) — the
 * required caption marks the comparison illustrative, per the honesty rule.
 */
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;
---

<div class={`overflow-hidden rounded-2xl border border-ink/10 bg-card shadow-[0_8px_30px_rgba(26,25,21,0.08)] ${cls}`}>
  <p class="px-6 pt-6 text-xs font-medium uppercase tracking-wider text-warm sm:px-8 sm:pt-8">The accuracy gap</p>

  <div class="mt-5 grid grid-cols-2 divide-x divide-ink/10 border-y border-ink/10">
    <!-- session-log estimate (muted) -->
    <div class="p-6 sm:p-8">
      <p class="text-xs font-medium uppercase tracking-wider text-ink/40">Session-log estimate</p>
      <p class="mt-3 font-mono text-xl font-bold text-ink/35 sm:text-2xl">estimate</p>
      <p class="mt-2 text-sm text-ink/40">reconstructed from the JSONL session logs</p>
    </div>

    <!-- billing-grade (your bill's source) -->
    <div class="bg-amber-light/40 p-6 sm:p-8">
      <div class="flex flex-wrap items-center gap-2">
        <p class="text-xs font-medium uppercase tracking-wider text-amber-deep">Billing-grade (your bill's source)</p>
        <HonestyBadge kind="billing-grade" />
      </div>
      <p class="mt-3 font-mono text-xl font-bold text-ink sm:text-2xl">your real cost</p>
      <p class="mt-2 text-sm text-ink/60">read from the statusline — the source behind your bill</p>
    </div>
  </div>

  <div class="px-6 py-5 sm:px-8">
    <p class="text-xs text-ink/50">
      Illustrative — your gap depends on your usage. Run <code class="font-mono text-ink/70">wtclaude compare</code> to see yours.
    </p>
    <div class="mt-4 flex flex-wrap items-center gap-2 font-mono text-sm">
      <code class="rounded bg-ink/5 px-2 py-1 text-ink/80">npx wtclaude setup</code>
      <span class="text-ink/40">→</span>
      <code class="rounded bg-ink/5 px-2 py-1 text-ink/80">wtclaude compare</code>
    </div>
  </div>
</div>
