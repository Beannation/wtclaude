---
/**
 * WTClaude question-burst mark, inlined so the center dot follows `currentColor`.
 * Spokes are always amber; the dot inherits the element's text color — so on a dark
 * surface set the wrapper to a light text color (e.g. `text-surface`) and the dot
 * inverts to light; on a light surface it stays ink. Sizing via `class`.
 */
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;
---

<svg viewBox="-62 -62 124 124" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="WTClaude" class={cls}>
  <g transform="rotate(0)"><line x1="0" y1="-12" x2="0" y2="-22" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/><path d="M 0,-22 C 0,-32 16,-35 16,-43 C 16,-52 4,-54 0,-46" fill="none" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/></g>
  <g transform="rotate(60)"><line x1="0" y1="-12" x2="0" y2="-22" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/><path d="M 0,-22 C 0,-32 16,-35 16,-43 C 16,-52 4,-54 0,-46" fill="none" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/></g>
  <g transform="rotate(120)"><line x1="0" y1="-12" x2="0" y2="-22" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/><path d="M 0,-22 C 0,-32 16,-35 16,-43 C 16,-52 4,-54 0,-46" fill="none" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/></g>
  <g transform="rotate(180)"><line x1="0" y1="-12" x2="0" y2="-22" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/><path d="M 0,-22 C 0,-32 16,-35 16,-43 C 16,-52 4,-54 0,-46" fill="none" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/></g>
  <g transform="rotate(240)"><line x1="0" y1="-12" x2="0" y2="-22" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/><path d="M 0,-22 C 0,-32 16,-35 16,-43 C 16,-52 4,-54 0,-46" fill="none" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/></g>
  <g transform="rotate(300)"><line x1="0" y1="-12" x2="0" y2="-22" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/><path d="M 0,-22 C 0,-32 16,-35 16,-43 C 16,-52 4,-54 0,-46" fill="none" stroke="#E8943A" stroke-width="7" stroke-linecap="round"/></g>
  <circle cx="0" cy="0" r="4.5" fill="currentColor"/>
</svg>
